# ── Banco de Dados (Neon.tech — gratuito) ────────────────────
DATABASE_URL=postgresql://usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/nomedb?sslmode=require

# ── Claude API (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── WhatsApp API (Evolution API / Z-API) ─────────────────────
WHATSAPP_API_URL=http://localhost:8080
WHATSAPP_INSTANCE=minha-instancia
WHATSAPP_TOKEN=meu_token_secreto

# ── Painel Admin ──────────────────────────────────────────────
# Token secreto para proteger as rotas da API administrativa.
# Gere um valor longo e aleatório (ex: openssl rand -hex 32)
ADMIN_TOKEN=troque_por_um_token_secreto_longo

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
